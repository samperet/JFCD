{
  "permissions": {
    "allow": [
      "Skill(run)",
      "Skill(run:*)",
      "Bash(curl -s http://localhost:8000/app.js)",
      "Bash(curl -s http://localhost:8000/manifest.json)",
      "Bash(node -c app.js)",
      "Bash(grep -E '\\\\.\\(js|json|css|html|md|gitignore\\)$')",
      "Bash(curl -s http://localhost:8000)",
      "Bash(git config *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git remote *)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(npx plugins *)",
      "Bash(ls -la ~/.claude/plugins/ 2>/dev/null || echo \"Plugins directory check\" && npx plugins list 2>&1 | head -20)"
    ]
  }
}
